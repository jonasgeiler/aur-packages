{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>jonasgeiler/renovate-config"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)PKGBUILD$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-.]+?) depName=(?<depName>[^\\s]+?)(?: (?:lookupName|packageName)=(?<packageName>[^\\s]+?))?(?: versioning=(?<versioning>[^\\s]+?))?(?: extractVersion=(?<extractVersion>[^\\s]+?))?(?: registryUrl=(?<registryUrl>[^\\s]+?))?\\s+pkgver\\s*=\\s*[\"']?(?<currentValue>.+?)[\"']?\\s"
      ]
    }
  },
  "packageRules": [
    {
      "matchFileNames": [
        "**/PKGBUILD"
      ],
      "extends": [
        "schedule:daily",
        ":automergeDisabled"
      ]
    }
  ],
  "customDatasources": {
    "sprinto": {
      "description": "Retrieves the latest version of Sprinto-hosted binaries",
      "defaultRegistryUrlTemplate": "https://static.sprinto.com/{{packageName}}/latest-linux.yml",
      "format": "yaml",
      "transformTemplates": [
        "{\"releases\":[{\"version\":$.version,\"releaseTimestamp\":$.releaseDate}]}"
      ]
    }
  },
  "logLevelRemap": [
    {
      "matchMessage": "/^Custom datasource/",
      "newLogLevel": "info"
    }
  ]
}
